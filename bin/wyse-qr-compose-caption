#!/usr/bin/env bash
set -euo pipefail

qr_file="${1:-}"
caption="${2:-}"

if [ -z "$qr_file" ] || [ -z "$caption" ]; then
  echo "Usage: wyse-qr-compose-caption <qr.png> <caption text>" >&2
  exit 2
fi

if [ ! -s "$qr_file" ]; then
  echo "wyse-qr-compose-caption: missing ${qr_file}" >&2
  exit 1
fi

im_cmd=""
if command -v magick >/dev/null 2>&1; then
  im_cmd="magick"
elif command -v convert >/dev/null 2>&1; then
  im_cmd="convert"
else
  echo "wyse-qr-compose-caption: imagemagick not installed" >&2
  exit 0
fi

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT
cp "$qr_file" "$tmp"

"$im_cmd" "$tmp" \
  \( -background '#00000099' -fill '#9CDCFE' -font DejaVu-Sans -pointsize 9 \
     -size 108x caption:"${caption}" \) \
  -gravity south -append \
  "$qr_file"
