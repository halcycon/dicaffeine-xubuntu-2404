#!/usr/bin/env bash
set -euo pipefail

qr_file="${1:-}"
caption="${2:-}"

if [ -z "$qr_file" ] || [ -z "$caption" ]; then
  echo "Usage: wyse-qr-compose-caption <qr.png> <caption text>" >&2
  exit 2
fi

if ! command -v convert >/dev/null 2>&1; then
  exit 0
fi

if [ ! -s "$qr_file" ]; then
  exit 1
fi

tmp="$(mktemp "${qr_file}.XXXXXX")"
cp "$qr_file" "$tmp"

convert "$tmp" \
  \( -background none -fill '#9CDCFE' -font DejaVu-Sans -pointsize 8 \
     -size 108x caption:"${caption}" \) \
  -gravity south -append \
  "$qr_file"

rm -f "$tmp"
