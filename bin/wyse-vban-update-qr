#!/usr/bin/env bash
set -euo pipefail

if [ -f /etc/default/wyse-vban ]; then
  # shellcheck disable=SC1091
  . /etc/default/wyse-vban
fi

QR_DIR="${QR_DIR:-/var/lib/wyse-ndi}"
QR_FILE="${QR_DIR}/vban-audiobox-qr.png"
URL_FILE="${QR_DIR}/vban-audiobox-url.txt"
MANAGER_PORT="${VBAN_MANAGER_PORT:-8088}"

mkdir -p "$QR_DIR" 2>/dev/null || true

primary_ip="$(
  ip -4 route get 1.1.1.1 2>/dev/null |
    awk '{for (i=1;i<=NF;i++) if ($i=="src") {print $(i+1); exit}}'
)"

if [ -z "${primary_ip:-}" ]; then
  primary_ip="$(hostname -I 2>/dev/null | awk '{print $1}')"
fi

if [ -n "${primary_ip:-}" ]; then
  display_target="http://${primary_ip}:${MANAGER_PORT}/audiobox.php"
else
  display_target="http://$(hostname -s).local:${MANAGER_PORT}/audiobox.php"
fi

old_target=""
if [ -f "$URL_FILE" ]; then
  old_target="$(cat "$URL_FILE" 2>/dev/null || true)"
fi

if [ "$display_target" != "$old_target" ] || [ ! -s "$QR_FILE" ]; then
  printf '%s\n' "$display_target" > "$URL_FILE"
  qrencode -o "$QR_FILE" -s 5 -m 2 "$display_target"

  target_user="${TARGET_USER:-$(id -un)}"
  if [ "$(id -u)" -eq 0 ]; then
    chown "${target_user}:${target_user}" "$QR_FILE" "$URL_FILE" 2>/dev/null || true
  fi

  chmod 0644 "$QR_FILE" "$URL_FILE" 2>/dev/null || true
fi

ln -sf "$QR_FILE" /tmp/vban-audiobox-qr.png 2>/dev/null || true
ln -sf "$URL_FILE" /tmp/vban-audiobox-url.txt 2>/dev/null || true
