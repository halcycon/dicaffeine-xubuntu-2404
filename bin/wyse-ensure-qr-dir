#!/usr/bin/env bash
set -euo pipefail

# Ensure /var/lib/wyse-ndi exists and is writable by the desktop user.

if [ -f /etc/default/wyse-wifi-setup ]; then
  # shellcheck disable=SC1091
  . /etc/default/wyse-wifi-setup
fi

if [ -f /etc/default/wyse-ndi-kit ]; then
  # shellcheck disable=SC1091
  . /etc/default/wyse-ndi-kit
fi

QR_DIR="${QR_DIR:-/var/lib/wyse-ndi}"
TARGET_USER="${TARGET_USER:-${WYSE_NDI_KIT_AUTO_UPDATE_USER:-${SUDO_USER:-ndi}}}"

if [ "$(id -u)" -ne 0 ]; then
  exec sudo TARGET_USER="$TARGET_USER" bash "$0"
fi

install -d -m 0755 -o "$TARGET_USER" -g "$TARGET_USER" "$QR_DIR"
chown "$TARGET_USER:$TARGET_USER" "$QR_DIR"
chmod 0755 "$QR_DIR"

if [ -d "$QR_DIR" ]; then
  find "$QR_DIR" -maxdepth 1 -type f \( -name '*.png' -o -name '*.txt' -o -name '*.meta' \) \
    -exec chown "$TARGET_USER:$TARGET_USER" {} + 2>/dev/null || true
fi
