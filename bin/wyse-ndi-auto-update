#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="/etc/default/wyse-ndi-kit"
STATE_FILE="/run/wyse-wifi-setup/state"
LOG_FILE="/var/log/wyse-ndi-kit-auto-update.log"
DEFAULT_KIT_DIR="/opt/wyse-ndi-kit"

log() {
  printf '[%s] %s\n' "$(date -Is)" "$*" | tee -a "$LOG_FILE"
}

load_config() {
  KIT_DIR="$DEFAULT_KIT_DIR"
  GIT_BRANCH=""
  UPDATE_USER="ndi"
  AUTO_UPDATE=1
  BOOT_DELAY=180
  RANDOM_DELAY=120

  if [ -f "$CONFIG_FILE" ]; then
    # shellcheck disable=SC1090
    . "$CONFIG_FILE" || true
  fi

  KIT_DIR="${WYSE_NDI_KIT_DIR:-$KIT_DIR}"
  GIT_BRANCH="${WYSE_NDI_KIT_GIT_BRANCH:-}"
  UPDATE_USER="${WYSE_NDI_KIT_AUTO_UPDATE_USER:-ndi}"
  AUTO_UPDATE="${WYSE_NDI_KIT_AUTO_UPDATE:-1}"
  BOOT_DELAY="${WYSE_NDI_KIT_AUTO_UPDATE_BOOT_DELAY_SEC:-180}"
  RANDOM_DELAY="${WYSE_NDI_KIT_AUTO_UPDATE_RANDOM_DELAY_SEC:-120}"
}

wifi_setup_active() {
  if [ ! -f "$STATE_FILE" ]; then
    return 1
  fi
  # shellcheck disable=SC1090
  . "$STATE_FILE" || true
  [ "${WYSE_WIFI_SETUP_ACTIVE:-0}" = "1" ]
}

detect_branch() {
  if [ -n "$GIT_BRANCH" ]; then
    printf '%s\n' "$GIT_BRANCH"
    return 0
  fi
  local branch
  branch="$(git -C "$KIT_DIR" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || true)"
  if [ -n "$branch" ]; then
    printf '%s\n' "$branch"
    return 0
  fi
  branch="$(git -C "$KIT_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  if [ -n "$branch" ] && [ "$branch" != "HEAD" ]; then
    printf '%s\n' "$branch"
    return 0
  fi
  printf '%s\n' "main"
}

run_git() {
  local update_home
  update_home="$(getent passwd "$UPDATE_USER" | cut -d: -f6)"
  sudo -u "$UPDATE_USER" env \
    HOME="$update_home" \
    GIT_TERMINAL_PROMPT=0 \
    git -C "$KIT_DIR" "$@"
}

main() {
  load_config

  if [ "$AUTO_UPDATE" != "1" ]; then
    log "Auto-update disabled in ${CONFIG_FILE}"
    exit 0
  fi

  if wifi_setup_active; then
    log "Skipping auto-update during Wi-Fi setup mode"
    exit 0
  fi

  if [ ! -d "$KIT_DIR/.git" ] || [ ! -x "$KIT_DIR/install-wyse-ndi.sh" ]; then
    log "Kit checkout missing or not a git repo: ${KIT_DIR}"
    exit 1
  fi

  if ! command -v git >/dev/null 2>&1; then
    log "git not installed"
    exit 1
  fi

  local branch local_rev remote_rev
  branch="$(detect_branch)"

  log "Checking ${KIT_DIR} (branch ${branch})"
  if ! run_git fetch --quiet origin "$branch" 2>>"$LOG_FILE"; then
    log "git fetch failed (no network or auth?)"
    exit 0
  fi

  local_rev="$(run_git rev-parse HEAD)"
  remote_rev="$(run_git rev-parse "origin/${branch}" 2>/dev/null || true)"

  if [ -z "$remote_rev" ]; then
    log "No origin/${branch} on remote"
    exit 0
  fi

  if [ "$local_rev" = "$remote_rev" ]; then
    log "Already up to date (${local_rev:0:8})"
    exit 0
  fi

  log "Update available ${local_rev:0:8} -> ${remote_rev:0:8}"
  if ! run_git merge --ff-only "origin/${branch}" 2>>"$LOG_FILE"; then
    log "Fast-forward pull failed; local changes or diverged history"
    exit 1
  fi

  log "Running install-wyse-ndi.sh --update"
  if ! env \
    TARGET_USER="$UPDATE_USER" \
    SUDO_USER="$UPDATE_USER" \
    UPDATE_MODE=1 \
    bash "$KIT_DIR/install-wyse-ndi.sh" --update >>"$LOG_FILE" 2>&1; then
    log "Update script failed — see ${LOG_FILE}"
    exit 1
  fi

  log "Auto-update complete"
}

mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || true
touch "$LOG_FILE" 2>/dev/null || true
chmod 0644 "$LOG_FILE" 2>/dev/null || true

main "$@"
