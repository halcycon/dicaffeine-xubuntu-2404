#!/usr/bin/env python3
"""Lightweight Pulse volume + VBAN stream presence (avoids heavy pactl list polling)."""

import json
import os
import re
import socket
import subprocess
import sys
import time

CACHE_TTL = 120


def runtime_dir():
    uid = os.getuid()
    return os.environ.get("XDG_RUNTIME_DIR") or f"/run/user/{uid}"


def pulse_env():
    env = os.environ.copy()
    runtime = runtime_dir()
    env.setdefault("XDG_RUNTIME_DIR", runtime)
    env.setdefault("DBUS_SESSION_BUS_ADDRESS", f"unix:path={runtime}/bus")
    env.setdefault("PULSE_SERVER", f"unix:{runtime}/pulse/native")
    return env


def run(cmd):
    try:
        return subprocess.check_output(cmd, text=True, stderr=subprocess.DEVNULL, env=pulse_env())
    except Exception:
        return ""


def cache_path():
    return os.path.join(runtime_dir(), "wyse-vban-pulse-cache.json")


def load_cache(label_hint):
    path = cache_path()
    if not os.path.isfile(path):
        return None
    try:
        with open(path, "r", encoding="utf-8") as handle:
            data = json.load(handle)
    except Exception:
        return None
    if not isinstance(data, dict):
        return None
    if data.get("label", "").lower() != (label_hint or "").lower():
        return None
    if time.time() - float(data.get("time", 0)) > CACHE_TTL:
        return None
    return data


def save_cache(label_hint, stream_index, media_name, app_name):
    payload = {
        "time": time.time(),
        "label": label_hint,
        "stream_index": stream_index,
        "media_name": media_name,
        "application_name": app_name,
    }
    with open(cache_path(), "w", encoding="utf-8") as handle:
        json.dump(payload, handle)


def parse_volume_percent(text):
    match = re.search(r"(\d+)%", text or "")
    return int(match.group(1)) if match else 100


def split_blocks(text, header):
    blocks = []
    for part in text.split(header):
        if not part.strip():
            continue
        first_line, _, rest = part.partition("\n")
        index = first_line.strip()
        if not index.isdigit():
            continue
        blocks.append((int(index), rest))
    return blocks


def score_stream_block(block, label_hint):
    media_match = re.search(r'media\.name = "([^"]*)"', block)
    app_match = re.search(r'application\.name = "([^"]*)"', block)
    media_name = media_match.group(1) if media_match else ""
    app_name = app_match.group(1) if app_match else ""
    score = 0
    hint = (label_hint or "").lower()
    if hint and hint in media_name.lower():
        score += 3
    if hint and hint in app_name.lower():
        score += 2
    if "vban" in app_name.lower() or "vban" in media_name.lower():
        score += 2
    return score, media_name, app_name


def refresh_cache(label_hint):
    detail = run(["pactl", "list", "sink-inputs"])
    if not detail:
        return None

    best = None
    for index, block in split_blocks(detail, "Sink Input #"):
        score, media_name, app_name = score_stream_block(block, label_hint)
        item = {
            "stream_index": index,
            "media_name": media_name,
            "application_name": app_name,
            "score": score,
        }
        if best is None or item["score"] > best["score"]:
            best = item

    if best is None or best["score"] == 0:
        return None

    save_cache(label_hint, best["stream_index"], best["media_name"], best["application_name"])
    return best


def stream_index_alive(stream_index):
    if not stream_index:
        return False
    short = run(["pactl", "list", "sink-inputs", "short"])
    prefix = f"{stream_index}\t"
    return any(line.startswith(prefix) for line in short.splitlines())


def default_sink_volume():
    return parse_volume_percent(run(["pactl", "get-sink-volume", "@DEFAULT_SINK@"]))


def default_sink_name():
    return run(["pactl", "get-default-sink"]).strip()


def stream_input_volume(stream_index):
    if not stream_index:
        return None
    return parse_volume_percent(run(["pactl", "get-sink-input-volume", str(stream_index)]))


def sample_vban_packets(port, seconds=0.18):
    """Best-effort packet rate when the port is not already bound by vban_receptor."""
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    try:
        sock.bind(("0.0.0.0", int(port)))
    except OSError:
        return {"available": False, "packets_per_second": 0.0}

    sock.settimeout(0.05)
    count = 0
    deadline = time.time() + seconds
    while time.time() < deadline:
        try:
            data, _addr = sock.recvfrom(4096)
        except socket.timeout:
            continue
        except OSError:
            break
        if len(data) >= 4 and data[0:4] == b"VBAN":
            count += 1
    sock.close()
    rate = count / seconds if seconds > 0 else 0.0
    return {"available": True, "packets_per_second": round(rate, 1)}


def build_status(label_hint, refresh=False, port=6980):
    if refresh:
        refresh_cache(label_hint)

    cache = load_cache(label_hint)
    if cache is None:
        refresh_cache(label_hint)
        cache = load_cache(label_hint)

    stream_index = cache.get("stream_index") if cache else None
    stream_alive = stream_index_alive(stream_index)
    stream_volume = stream_input_volume(stream_index) if stream_alive else None
    sink_volume = default_sink_volume()
    packet_sample = sample_vban_packets(port)

    signal = {
        "mode": "presence",
        "peaks_available": False,
        "stream_playing": stream_alive,
        "packet_probe_available": packet_sample["available"],
        "packets_per_second": packet_sample["packets_per_second"],
    }

    if packet_sample["available"] and packet_sample["packets_per_second"] > 0:
        signal["mode"] = "packets"
        signal["activity"] = min(1.0, packet_sample["packets_per_second"] / 120.0)
    elif stream_alive:
        signal["mode"] = "presence"
        signal["activity"] = 1.0
    else:
        signal["activity"] = 0.0

    return {
        "ok": True,
        "connected": bool(stream_alive),
        "stream": {
            "index": stream_index,
            "media_name": cache.get("media_name") if cache else "",
            "application_name": cache.get("application_name") if cache else "",
            "volume_percent": stream_volume,
            "playing": stream_alive,
        }
        if stream_index
        else None,
        "sink": {
            "name": default_sink_name(),
            "volume_percent": sink_volume,
        },
        "signal": signal,
    }


def main():
    args = [arg for arg in sys.argv[1:] if arg]
    refresh = "--refresh-cache" in args
    args = [arg for arg in args if arg != "--refresh-cache"]

    label_hint = args[0] if args else "VBAN AudioBox"
    port = int(args[1]) if len(args) > 1 else 6980

    print(json.dumps(build_status(label_hint, refresh=refresh, port=port)))
    return 0


if __name__ == "__main__":
    sys.exit(main())
